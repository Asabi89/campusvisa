# CampusVisa Environment Variables

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL - Production)
DB_NAME=campusvisa
DB_USER=campusvisa_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis (Channels + Celery)
REDIS_URL=redis://localhost:6379/0

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# AWS S3
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_STORAGE_BUCKET_NAME=campusvisa-files

# Google Calendar / Meet
GOOGLE_CALENDAR_CREDENTIALS_FILE=env/google-credentials.json
GOOGLE_CALENDAR_ID=primary

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20
EMAIL_HOST_USER=selinaonio@gmail.com
EMAIL_HOST_PASSWORD=lwxn wiow zaxf ovcx
DEFAULT_FROM_EMAIL=CampusVisa <no-reply@campusvisa.com>

# Firebase Cloud Messaging (FCM)
FCM_ENABLED=False
FCM_DRY_RUN=False
FCM_PROJECT_ID=your-firebase-project-id
FCM_CREDENTIALS_FILE=env/firebase-service-account.json
